{
  "version": 2,
  "functions": {
    "api/index.ts": {
      "maxDuration": 60,
      "memory": 1024
    }
  },
  "redirects": [
    {
      "source": "/api",
      "destination": "/api/docs",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/api/ping",
      "destination": "api/ping.ts"
    },
    {
      "source": "/api/(.*)",
      "destination": "api/index.ts"
    }
  ]
}
